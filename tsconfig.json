{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["esnext", "dom"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./docs/.vitepress/*"]
    }
  },
  "include": ["**/*.ts", "**/*.vue", "**/*.md"],
  "exclude": ["**/node_modules/**", "**/dist/**"],
  "vueCompilerOptions": {
    "vitePressExtensions": [".md"]
  }
}
