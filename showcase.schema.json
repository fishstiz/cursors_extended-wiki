{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "packs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "anyOf": [{ "required": ["modrinthId"] }, { "required": ["curseforgeId"] }],
        "properties": {
          "name": { "type": "string" },
          "modrinthId": { "type": "string" },
          "curseforgeId": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
